<script type="c94e5ed78eeac3bfa4e99e95-text/javascript">
jQuery(document).ready(function() {
    function updateColspan() {
        var columnCount = jQuery('.table-compare thead th').length;
        // Set initial colspan based on column count
        if (columnCount === 2) {
            jQuery('.table-compare-column-head').attr('colspan', '2');
        } else if (columnCount === 3) {
            jQuery('.table-compare-column-head').attr('colspan', '3');
        } else if (columnCount === 4) {
            jQuery('.table-compare-column-head').attr('colspan', '4');
        }
    }

    // Initialize colspan on page load
    updateColspan();

    // Event handler for the remove card button
    jQuery('.remove-card').on('click', function() {
        var currentColspan = parseInt(jQuery('.table-compare-column-head').attr('colspan'), 10);
        var columnCount = jQuery('.table-compare thead th').length;

        // Decrease colspan value based on current value and column count
        if (currentColspan > 1) {
            jQuery('.table-compare-column-head').attr('colspan', currentColspan - 1);
			jQuery('.caexmsg').remove();
        }
    });
});
</script>
